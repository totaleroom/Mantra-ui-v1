# =============================================================
# Mantra AI — PRODUCTION Environment Template
# Copy this to .env and fill in YOUR actual domain/IP values
# NEVER commit this file with real values
# =============================================================

# ═════════════════════════════════════════════════════════════
# YOUR VPS / DOMAIN CONFIGURATION
# Replace these with your actual production values
# ═════════════════════════════════════════════════════════════

# Your VPS IP address or domain name
# Example with IP: http://43.157.223.29
# Example with domain: https://api.mantra.yourdomain.com
VPS_IP_OR_DOMAIN=https://api.mantra.yourdomain.com
FRONTEND_DOMAIN=https://app.mantra.yourdomain.com

# ═════════════════════════════════════════════════════════════
# [FRONTEND_NEXTJS] — Public Variables (bundled to browser)
# ═════════════════════════════════════════════════════════════

NEXT_PUBLIC_BASE_URL=${FRONTEND_DOMAIN}
NEXT_PUBLIC_API_URL=${VPS_IP_OR_DOMAIN}
NEXT_PUBLIC_WS_URL=wss://${VPS_IP_OR_DOMAIN#*://}  # Removes http:// or https:// prefix, adds wss://
NEXT_PUBLIC_EVO_INSTANCE_NAME=mantra_instance
NEXT_PUBLIC_BACKEND_URL=${VPS_IP_OR_DOMAIN}
NEXT_PUBLIC_EVO_URL=${VPS_IP_OR_DOMAIN}:8080

# Feature flags
NEXT_PUBLIC_ENABLE_DEVTOOLS=false
NEXT_PUBLIC_ENABLE_MOCK_DATA=false

# ═════════════════════════════════════════════════════════════
# [BACKEND_GO] — Server Configuration
# ═════════════════════════════════════════════════════════════

PORT=3001
APP_ENV=production

# CRITICAL: Generate with: openssl rand -base64 48
# Must be identical in both backend and frontend middleware
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING_MINIMUM_THIRTY_TWO_CHARS_LONG

# Frontend URL for CORS policy
FRONTEND_URL=${FRONTEND_DOMAIN}

# Internal URL for server-to-server calls
BACKEND_INTERNAL_URL=http://backend:3001

# ═════════════════════════════════════════════════════════════
# [DATABASE_POSTGRES] — Data Persistence
# ═════════════════════════════════════════════════════════════

# PostgreSQL connection string
DATABASE_URL=postgres://mantra:CHANGE_THIS_PASSWORD@postgres:5432/mantra_db?sslmode=disable

# Individual credentials (used by Docker Compose)
POSTGRES_USER=mantra
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_16_CHARS_MIN
POSTGRES_DB=mantra_db

# Redis connection string
REDIS_URL=redis://redis:6379

# ═════════════════════════════════════════════════════════════
# [WHATSAPP_PROVIDER] — Evolution API Integration
# ═════════════════════════════════════════════════════════════

# Evolution API configuration
EVO_API_URL=http://evolution:8080
EVO_API_KEY=your-evolution-api-key-from-dashboard
EVO_INSTANCE_NAME=mantra_instance

# Legacy aliases (mapped to EVO_* by backend)
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=${EVO_API_KEY}
EVOLUTION_SERVER_URL=${VPS_IP_OR_DOMAIN}:8080

# ═════════════════════════════════════════════════════════════
# [AGENTIC_AI] — LLM Provider Integration
# ═════════════════════════════════════════════════════════════

# Hermes agent authentication token
# Generate with: openssl rand -base64 32
HERMES_AUTH_TOKEN=CHANGE_THIS_TO_32_CHAR_RANDOM_TOKEN

# Webhook URL for agent callbacks
AGENT_CALLBACK_URL=${VPS_IP_OR_DOMAIN}/api/webhook/agent

# AI Provider API Keys (at least one required)
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk-your-groq-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# ═════════════════════════════════════════════════════════════
# [DEPLOYMENT_VPS] — Production VPS Settings
# ═════════════════════════════════════════════════════════════

DOCKER_IMAGE_TAG=latest
LOG_LEVEL=INFO

# Optional: Cloudflare Tunnel token (if using cloudflared)
# TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ═════════════════════════════════════════════════════════════
# SECURITY CHECKLIST - Before deploying:
# ═════════════════════════════════════════════════════════════
# ☐ JWT_SECRET is at least 32 characters and randomly generated
# ☐ POSTGRES_PASSWORD is strong (16+ chars, mixed case, symbols)
# ☐ HERMES_AUTH_TOKEN is randomly generated and kept secret
# ☐ EVO_API_KEY is valid from Evolution API dashboard
# ☐ VPS_IP_OR_DOMAIN uses HTTPS in production (not http://)
# ☐ All AI provider API keys are valid
# ☐ .env file is in .gitignore and NOT committed
# ☐ Default passwords will be changed after first login
# ═════════════════════════════════════════════════════════════
