# =============================================================
# Mantra AI — Git Ignore Rules
# CRITICAL: Keep secrets and build artifacts out of version control
# =============================================================

# ─────────────────────────────────────────────────────────────
# [SECURITY_CRITICAL] Environment Variables & Secrets
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.production.example
*.pem
*.key
*.cert
secrets/
config/secrets/

# Master credentials registry (local-only, for AI agents)
CREDENTIALS.md
CREDENTIALS.local.md
credentials.local.*

# ─────────────────────────────────────────────────────────────
# [DEPENDENCIES] Package Managers
# ─────────────────────────────────────────────────────────────
node_modules/
vendor/
pnpm-lock.yaml
package-lock.json
yarn.lock

# ─────────────────────────────────────────────────────────────
# [BUILD_OUTPUTS] Compiled/Bundled Code
# ─────────────────────────────────────────────────────────────
.next/
dist/
build/
out/
target/
*.tsbuildinfo

# Go backend binaries
backend/mantra-backend
backend/*.exe
backend/*.dll
backend/*.so
backend/*.dylib

# ─────────────────────────────────────────────────────────────
# [LOGS] Log Files & Debug Output
# ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
log/

# ─────────────────────────────────────────────────────────────
# [LARGE_ARTIFACTS] Skill Assets & Local Data
# ─────────────────────────────────────────────────────────────
.local/
.agents/
.config/
.vercel/
.snowflake/
.v0-trash/

# Attached assets (keep in repo only if < 1MB each)
# Uncomment if assets should not be tracked:
# attached_assets/

# ─────────────────────────────────────────────────────────────
# [IDE] Editor & IDE Files
# ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-*
*.code-workspace

# ─────────────────────────────────────────────────────────────
# [v0_SANDBOX] v0 Development Artifacts
# ─────────────────────────────────────────────────────────────
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.npmrc
next.user-config.*

# ─────────────────────────────────────────────────────────────
# [TESTING] Test Outputs & Coverage
# ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─────────────────────────────────────────────────────────────
# [MISC] Miscellaneous
# ─────────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/

# Replit specific
.replit
replit.nix
.breakpoints

# Docker volumes (if stored locally)
docker-volumes/
*.volume

# Local database files
*.sqlite
*.sqlite3
*.db
