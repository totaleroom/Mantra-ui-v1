# =============================================================
# Mantra AI — Master Environment Variable Reference
# Copy to .env (never commit the real .env)
# =============================================================
#
# TWO DEPLOYMENT PROFILES supported — pick one:
#
# A) PUBLIC SAAS (multi-tenant, public domain, Let's Encrypt via Coolify)
#    Set NEXT_PUBLIC_*_URL and PUBLIC_BACKEND_URL to https://<yourdomain>.
#    UFW opens 22/80/443.
#
# B) SINGLE-USER / TAILSCALE (private, no public domain)    Set all public URLs to the VPS Tailscale hostname or tailnet IP:
#      NEXT_PUBLIC_API_URL=http://mantra-vps:3001
#      NEXT_PUBLIC_WS_URL=ws://mantra-vps:3001
#      PUBLIC_BACKEND_URL=http://backend:3001   ← container-internal!
#    UFW opens only 22 + tailscale0. See .agent/09-single-user-deployment.md.
# =============================================================

# ─────────────────────────────────────────────────────────────
# [FRONTEND_NEXTJS] — Public Variables (bundled to browser)
# These are exposed to the client - NEVER put secrets here
# ─────────────────────────────────────────────────────────────

# Frontend public base URL (used in absolute links, meta tags, OG images)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# Go Backend API URL for client-side requests
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# WebSocket URL for real-time inbox (ws:// for dev, wss:// for prod)
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com

# Evolution API instance name (safe to expose - identifies the WA instance)
NEXT_PUBLIC_EVO_INSTANCE_NAME=mantra_instance

# Optional: Additional public backend URL reference
NEXT_PUBLIC_BACKEND_URL=https://api.your-domain.com

# Optional: Direct Evolution API URL for client-side QR fetching
NEXT_PUBLIC_EVO_URL=https://evo.your-domain.com

# ─────────────────────────────────────────────────────────────
# [BACKEND_GO] — Server Configuration
# Go Fiber backend - ALL server-side only
# ─────────────────────────────────────────────────────────────

# Server port (Go backend listens here)
PORT=3001

# Application environment
APP_ENV=development                     # development | production | test

# JWT signing secret (SHARED between Go and Next.js middleware)
# CRITICAL: Must be identical in both environments
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-64-char-random-string-minimum-thirty-two

# Shared secret Evolution API sends in the `X-Webhook-Secret` header when
# it forwards WhatsApp events to /api/webhooks/evolution.
# REQUIRED — docker-compose refuses to start without it.
# Generate with: openssl rand -base64 32
WEBHOOK_SECRET=replace-with-32-char-random-secret-for-webhook-auth

# Publicly-reachable URL of THIS backend (used when auto-registering the
# webhook with Evolution and when Evolution POSTs back to us).
# Production example:   https://api.your-domain.com
# Tailscale/LAN:        http://<host>:3001
# Docker-only internal: http://backend:3001
PUBLIC_BACKEND_URL=https://api.your-domain.com

# Frontend URL for CORS policy (where your Next.js app is hosted)
FRONTEND_URL=https://your-app.vercel.app

# Internal URL the Next.js server actions use to call this backend.
# In Docker compose leave as http://backend:3001 (service name + port).
# Locally without Docker: http://localhost:3001
BACKEND_INTERNAL_URL=http://backend:3001

# ─────────────────────────────────────────────────────────────
# [DATABASE_POSTGRES] — Data Persistence
# PostgreSQL + Redis configuration
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (used by Go backend)
DATABASE_URL=postgres://mantra:secure_password@localhost:5432/mantra_db?sslmode=disable

# Individual PostgreSQL credentials (used by Docker Compose)
POSTGRES_USER=mantra
POSTGRES_PASSWORD=replace-with-secure-password-16-chars-min
POSTGRES_DB=mantra_db

# Redis connection string (caching, sessions, real-time data)
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# [WHATSAPP_PROVIDER] — Evolution API Integration
# WhatsApp gateway server configuration
# ─────────────────────────────────────────────────────────────

# ═════════════════════════════════════════════════════════════
# PRIMARY VARIABLES (Use these - canonical naming)
# ═════════════════════════════════════════════════════════════

# Evolution API base URL (where Evolution API server is running)
EVO_API_URL=https://evo.your-domain.com

# Evolution API authentication key (from Evolution API dashboard)
EVO_API_KEY=your-evolution-api-key-here

# Default instance name for this deployment
EVO_INSTANCE_NAME=mantra_instance

# ═════════════════════════════════════════════════════════════
# LEGACY VARIABLES (Backward compatibility - optional)
# ═════════════════════════════════════════════════════════════

# Alternative names (backend maps these to EVO_* variants)
EVOLUTION_API_URL=https://evo.your-domain.com
EVOLUTION_API_KEY=your-evolution-api-key-here

# Evolution server's own public URL (for SERVER_URL config in Evolution)
EVOLUTION_SERVER_URL=https://evo.your-domain.com

# ─────────────────────────────────────────────────────────────
# [AGENTIC_AI] — LLM Provider Integration
# AI response generation and agent callbacks
# ─────────────────────────────────────────────────────────────

# Hermes agent authentication token (server-only secret)
# Used to authenticate incoming webhook calls from agent services
HERMES_AUTH_TOKEN=replace-with-secure-random-token-min-32-chars

# Webhook URL this backend exposes for agent callbacks
# Must be publicly accessible from the internet
AGENT_CALLBACK_URL=https://api.your-domain.com/api/webhook/agent

# OpenAI API key (for GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Groq API key (for fast inference - Llama, Mixtral, etc.)
GROQ_API_KEY=gsk-your-groq-key-here

# OpenRouter API key (unified LLM gateway)
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# ─────────────────────────────────────────────────────────────
# [FEATURE_FLAGS] — Development & Debugging
# Toggle features without code changes
# ─────────────────────────────────────────────────────────────

# Enable React Query DevTools in browser (development only)
NEXT_PUBLIC_ENABLE_DEVTOOLS=false

# Use mock data instead of live API calls (for offline development)
NEXT_PUBLIC_ENABLE_MOCK_DATA=false

# ─────────────────────────────────────────────────────────────
# [DEPLOYMENT_VPS] — Production VPS Settings
# Additional variables for Docker Compose deployment
# ─────────────────────────────────────────────────────────────

# Docker image tag (for version pinning)
DOCKER_IMAGE_TAG=latest

# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Cloudflare Tunnel token (if using cloudflared)
# TUNNEL_TOKEN=your-cloudflare-tunnel-token

# SSL/TLS settings
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# ─────────────────────────────────────────────────────────────
# SECURITY CHECKLIST
# ─────────────────────────────────────────────────────────────
# ☐ JWT_SECRET is at least 32 characters and randomly generated
# ☐ POSTGRES_PASSWORD is strong (16+ chars, mixed case, symbols)
# ☐ HERMES_AUTH_TOKEN is randomly generated and kept secret
# ☐ All API keys (EVO_API_KEY, OPENAI_API_KEY, etc.) are valid
# ☐ FRONTEND_URL matches your actual deployment URL
# ☐ NEXT_PUBLIC_* vars contain NO secrets
# ☐ .env file is in .gitignore and NOT committed
# ☐ Production uses HTTPS URLs (not http://localhost)
# ─────────────────────────────────────────────────────────────
