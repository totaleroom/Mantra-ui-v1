# =============================================================
# Mantra AI — Master Environment Variable Reference
# Copy to .env (never commit the real .env)
# =============================================================

# ── [CORE] ───────────────────────────────────────────────────
PORT=3001
APP_ENV=development                     # development | production
JWT_SECRET=replace-with-64-char-random-string

# ── [DATABASE] ───────────────────────────────────────────────
DATABASE_URL=postgres://mantra:password@localhost:5432/mantra_db?sslmode=disable
POSTGRES_USER=mantra
POSTGRES_PASSWORD=replace-with-secure-password
POSTGRES_DB=mantra_db

REDIS_URL=redis://localhost:6379

# ── [EVOLUTION_API] ──────────────────────────────────────────
# Primary aliases (canonical — use these)
EVO_API_URL=https://your-vps.com
EVO_API_KEY=your-evolution-api-key
EVO_INSTANCE_NAME=mantra_instance

# Legacy aliases (still accepted — mapped to EVO_*)
EVOLUTION_API_URL=https://your-vps.com
EVOLUTION_API_KEY=your-evolution-api-key

# Evolution server's own public URL (used in its SERVER_URL config)
EVOLUTION_SERVER_URL=https://your-vps.com

# ── [AGENTIC_AI] ─────────────────────────────────────────────
# Hermes agent authentication token (server-only, never expose client-side)
HERMES_AUTH_TOKEN=replace-with-secret-token

# Webhook URL this backend exposes for agent callbacks
AGENT_CALLBACK_URL=https://your-api-domain.com/api/webhook/agent

# AI provider API keys (at least one required for AI features)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...

# ── [DEPLOYMENT] ─────────────────────────────────────────────
# Frontend URL — drives CORS policy in the Go backend
FRONTEND_URL=https://your-app.vercel.app

# Public base URL of this app (used in absolute links, meta tags)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ── [FRONTEND — NEXT.JS PUBLIC VARS] ─────────────────────────
# These are bundled into the browser bundle (safe to expose)
NEXT_PUBLIC_API_URL=https://your-api-domain.com
NEXT_PUBLIC_WS_URL=wss://your-api-domain.com
NEXT_PUBLIC_EVO_INSTANCE_NAME=mantra_instance

# Feature flags
NEXT_PUBLIC_ENABLE_DEVTOOLS=false
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
