PORT=3001
APP_ENV=development

DATABASE_URL=postgres://mantra:password@localhost:5432/mantra_db?sslmode=disable
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-long-random-secret-in-production

CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://your-app.vercel.app

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# Public URL Evolution calls for webhooks. Must be reachable from the
# Evolution container (in docker-compose: http://backend:3001).
# In production, set to your public API domain, e.g. https://api.mantra.yourdomain.com
PUBLIC_BACKEND_URL=http://backend:3001

# Shared secret Evolution sends in the X-Webhook-Secret header. Generate
# with: openssl rand -base64 32. Must match the value configured in
# Evolution's webhook config (or rely on auto-registration at instance create).
WEBHOOK_SECRET=change-me-to-a-long-random-secret

# Hermes agent token — required in production, can be blank in dev.
HERMES_AUTH_TOKEN=
AGENT_CALLBACK_URL=
