# =============================================================
# Mantra AI — Production Environment Variables
# Copy this to .env and fill in all values before deploying.
# NEVER commit the actual .env file to version control.
# =============================================================

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=mantra
POSTGRES_PASSWORD=generate-a-secure-password-here
POSTGRES_DB=mantra_db

# ── Redis ─────────────────────────────────────────────────────
# (auto-configured via docker-compose internal network)

# ── Go Backend ────────────────────────────────────────────────
JWT_SECRET=generate-a-64-char-random-string-here

# ── CORS / Frontend ───────────────────────────────────────────
# Set to your exact Vercel deployment URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── Evolution API ─────────────────────────────────────────────
EVOLUTION_API_KEY=generate-a-secure-api-key-here
EVOLUTION_SERVER_URL=https://api.yourdomain.com

# ── Coolify / Cloudflare Tunnel ───────────────────────────────
# This is the public URL for the Go backend (used by Evolution API internally)
# BACKEND_PUBLIC_URL=https://api.yourdomain.com
